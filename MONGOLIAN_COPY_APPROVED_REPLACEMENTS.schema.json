{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Approved Mongolian copy replacement manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "approval_status", "replacements"],
  "properties": {
    "schema_version": { "const": 1 },
    "approval_status": { "enum": ["EMPTY_NOT_APPROVED", "APPROVED"] },
    "replacements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source_file", "surface", "current_exact_text", "approved_exact_text", "approved_by", "approval_date", "notes"],
        "properties": {
          "id": { "type": "string", "pattern": "^COPY-[0-9]{4,}$" },
          "source_file": { "type": "string", "minLength": 1 },
          "surface": { "type": "string", "minLength": 1 },
          "current_exact_text": { "type": "string", "minLength": 1 },
          "approved_exact_text": { "type": "string", "minLength": 1 },
          "approved_by": { "const": "product_owner" },
          "approval_date": { "type": "string", "format": "date" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
