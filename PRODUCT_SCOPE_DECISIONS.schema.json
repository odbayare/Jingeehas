{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Product scope decision registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "decisions"],
  "properties": {
    "schema_version": { "const": 1 },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "decision_date", "approved_by", "decision", "feature", "retained_product_scope", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^SCOPE-[0-9]{4,}$" },
          "decision_date": { "const": "2026-07-16" },
          "approved_by": { "const": "product_owner" },
          "decision": { "const": "REMOVE_FEATURE" },
          "feature": { "const": "seven_day_assessment" },
          "retained_product_scope": { "const": "one_time_assessment_only" },
          "status": { "const": "APPLIED" }
        }
      }
    }
  }
}
