{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Applied owner correction registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "records"],
  "properties": {
    "schema_version": { "const": 1 },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source_file", "surface", "former_text_marker", "approved_exact_text", "approved_by", "approval_date", "status", "notes"],
        "properties": {
          "id": { "type": "string", "pattern": "^COPY-[0-9]{4,}$" },
          "source_file": { "type": "string", "minLength": 1 },
          "surface": { "type": "string", "minLength": 1 },
          "former_text_marker": { "const": "[CROSS_PROJECT_NAME_REMOVED]" },
          "approved_exact_text": { "type": "string", "minLength": 1 },
          "approved_by": { "const": "product_owner" },
          "approval_date": { "type": "string", "format": "date" },
          "status": { "const": "APPLIED" },
          "notes": { "type": "string", "minLength": 1 }
        },
        "not": {
          "anyOf": [
            { "required": ["former_exact_text"] },
            { "required": ["current_exact_text"] },
            { "required": ["old_text"] },
            { "required": ["old_url"] },
            { "required": ["former_url"] },
            { "required": ["encoded_text"] }
          ]
        }
      }
    }
  }
}
