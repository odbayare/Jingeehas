# Jingeehas staging/preview server-side database gateway.
JINGEEHAS_DATABASE_API_URL=https://nemgfbanmwqudjfzddrn.supabase.co/functions/v1/jingeehas-database-gateway

# Supabase service-role secret. Leave blank in the repository.
# Configure only through Netlify environment settings and scope to staging/preview first.
# Never expose this value to frontend code or a NEXT_PUBLIC_, VITE_, or PUBLIC_ variable.
# Never paste it into GitHub issues, pull requests, chat, logs, screenshots, or artifacts.
# Rotate the service-role secret immediately if it is exposed.
JINGEEHAS_DATABASE_API_KEY=

# Email-only recovery through Resend. Keep all values server-side.
RECOVERY_ENCRYPTION_KEY=
RECOVERY_HASH_PEPPER=
RECOVERY_DELIVERY_API_URL=https://api.resend.com/emails
RECOVERY_DELIVERY_API_KEY=
RECOVERY_SENDER_EMAIL=no-reply@mail.jingeehas.fit
RECOVERY_SENDER_NAME=Jingeehas
RECOVERY_CHANNEL=email
RECOVERY_RATE_LIMIT_STORE=database
